@prefix capec: <https://w3id.org/lmodel/capec/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

capec:AttackPatternCatalog a sh:NodeShape ;
    rdfs:comment """The root element used to hold an enumerated catalog of common attack patterns.
Each catalog can be organized by optional Views and Categories. The catalog also
contains a list of all External_References that may be shared throughout the
individual attack patterns. The required Name and Version attributes are used to
uniquely identify the catalog. The required Date attribute identifies the date when
this catalog was created or last updated.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class capec:AttackPattern ;
            sh:description "The collection of attack patterns defined in this catalog." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path capec:attack_patterns ],
        [ sh:class capec:View ;
            sh:description "The collection of views providing perspectives on the attack pattern catalog." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path capec:views ],
        [ sh:datatype xsd:date ;
            sh:description "The date when this catalog was created or last updated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path capec:entry_date ],
        [ sh:class capec:Category ;
            sh:description "The collection of categories organizing attack patterns in this catalog." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path capec:categories ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this catalog, used to uniquely identify it." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:version ],
        [ sh:class capec:ExternalReference ;
            sh:description "The collection of external references shared throughout the catalog entries." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path capec:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "The name of this catalog, used to uniquely identify it." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:name ] ;
    sh:targetClass capec:AttackPatternCatalog .

capec:RelatedWeakness a sh:NodeShape ;
    rdfs:comment """A reference to a CWE (Common Weakness Enumeration) weakness associated with an
attack pattern. The association implies a weakness that must exist for a given
attack to be successful. If multiple weaknesses are listed, any of them (but not
necessarily all) may be present for the attack to succeed.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The CWE integer identifier of the related weakness (e.g., 79 for CWE-79: Improper Neutralization of Input During Web Page Generation)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:cwe_id ] ;
    sh:targetClass capec:RelatedWeakness .

capec:AlternateTerm a sh:NodeShape ;
    rdfs:comment "Another name or term used to describe an attack pattern. Provides context for the alternate term by which the attack pattern may be known." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The actual alternate term or name for the attack pattern." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:term ],
        [ sh:datatype xsd:string ;
            sh:description "Context and explanation for each alternate term by which this attack pattern may be known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:description ] ;
    sh:targetClass capec:AlternateTerm .

capec:AttackPattern a sh:NodeShape ;
    rdfs:comment """An attack pattern is an abstraction mechanism for helping describe how an attack is
executed. Each pattern defines a challenge that an attacker may face, provides a
description of the common technique(s) used to meet the challenge, and presents
recommended methods for mitigating an actual attack. Attack patterns help categorize
attacks in a meaningful way in an effort to provide a coherent way of teaching
designers and developers how their systems may be attacked and how they can effectively
defend them.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The conditions that must exist in order for an attack leveraging this pattern to succeed." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path capec:prerequisites ],
        [ sh:class capec:AttackStep ;
            sh:description "A detailed step-by-step flow of the attack pattern, listing the typical steps performed by an adversary when leveraging the given technique. Usually only applicable to Detailed abstraction level attack patterns." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path capec:execution_flow ],
        [ sh:class capec:ContentHistory ;
            sh:description "Tracks the original author of this entry and any subsequent modifications to the content, providing a means of contacting authors and modifiers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path capec:content_history ],
        [ sh:description "An overall average severity value for attacks that leverage this attack pattern, with the understanding that it will not be completely accurate for all attacks." ;
            sh:in ( "Very High" "High" "Medium" "Low" "Very Low" ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path capec:typical_severity ],
        [ sh:datatype xsd:integer ;
            sh:description "References to CWE weaknesses associated with this attack pattern. Any of the weaknesses (not necessarily all) may be present for the attack to be successful." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path capec:related_weaknesses ],
        [ sh:description "The abstraction level for this attack pattern. Defines whether this is a Meta, Standard, or Detailed level pattern." ;
            sh:in ( "Meta" "Standard" "Detailed" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path capec:abstraction ],
        [ sh:class capec:Note ;
            sh:description "Additional comments and notes about this entry that cannot be captured using the other available elements." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path capec:notes ],
        [ sh:class capec:RelatedAttackPattern ;
            sh:description "References to other attack patterns that give insight to similar items at higher and lower levels of abstraction." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path capec:related_attack_patterns ],
        [ sh:description "The development and usage status level for this entry. Please refer to the StatusEnum enumeration for a list of valid values and their meanings." ;
            sh:in ( "Deprecated" "Draft" "Incomplete" "Obsolete" "Stable" "Usable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path capec:status ],
        [ sh:datatype xsd:string ;
            sh:description "Additional details important to this attack pattern beyond what is conveyed in the main description, but not necessary to understand the fundamental concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path capec:extended_description ],
        [ sh:description "An overall average likelihood value for attacks that leverage this attack pattern, with the understanding that it will not be completely accurate for all attacks." ;
            sh:in ( "High" "Medium" "Low" "Unknown" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path capec:likelihood_of_attack ],
        [ sh:datatype xsd:string ;
            sh:description "Actions or approaches to prevent or mitigate the risk of an attack that leverages this attack pattern, aimed at improving system resiliency, reducing attack surface, or reducing impact." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path capec:mitigations ],
        [ sh:class capec:Consequence ;
            sh:description "Individual consequences associated with this attack pattern, specifying the security properties violated, technical impacts, and likelihoods." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path capec:consequences ],
        [ sh:datatype xsd:string ;
            sh:description "The resources (e.g., CPU cycles, IP addresses, tools) required by an adversary to effectively execute this type of attack." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path capec:resources_required ],
        [ sh:class capec:Skill ;
            sh:description "The level of skills or specific knowledge needed by an adversary to execute this type of attack." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path capec:skills_required ],
        [ sh:class capec:TaxonomyMapping ;
            sh:description "Mappings from this entry to equivalent or related entries in taxonomies outside of CAPEC, such as ATT&CK, WASC, or OWASP Attacks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path capec:taxonomy_mappings ],
        [ sh:datatype xsd:string ;
            sh:description "Activities, events, conditions or behaviors that may indicate that an attack leveraging this pattern is imminent, in progress, or has occurred." ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path capec:indicators ],
        [ sh:class capec:AlternateTerm ;
            sh:description "One or more other names by which this attack pattern may be known." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path capec:alternate_terms ],
        [ sh:class capec:Reference ;
            sh:description "Links to external references for further reading and insight into this entry. Should be used when the entry is based on external sources or projects." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path capec:references ],
        [ sh:datatype xsd:string ;
            sh:description "Descriptive title used to give the reader an idea of what the entry represents. All words in the name should be capitalized except for articles and prepositions unless they begin or end the name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:name ],
        [ sh:datatype xsd:string ;
            sh:description "One or more concrete example instances of this attack pattern to help the reader understand its nature, context, and variability in practical terms." ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path capec:example_instances ],
        [ sh:datatype xsd:string ;
            sh:description """A high level description of the attack pattern. The description should be no
longer than a few sentences and should include how malicious input is initially
supplied, the weakness being exploited, and the resulting negative technical
impact. A full step-by-step description belongs in the Execution_Flow element.""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path capec:description ],
        [ sh:datatype xsd:integer ;
            sh:description "Unique integer identifier for the entry. Considered static for the lifetime of the entry. If an entry becomes deprecated, the identifier is not reused and a placeholder is left in the catalog." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:id ] ;
    sh:targetClass capec:AttackPattern .

capec:AttackStep a sh:NodeShape ;
    rdfs:comment """An individual step in the execution flow of an attack pattern. Provides a detailed
description of a specific action typically performed by an adversary during the
attack, along with the phase of the attack it belongs to and any specific techniques
used.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The sequential step number within the execution flow." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:step ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the actions taken by the adversary during this step of the attack." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:description ],
        [ sh:description "The phase of the attack this step belongs to (Explore, Experiment, or Exploit)." ;
            sh:in ( "Explore" "Experiment" "Exploit" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path capec:phase ],
        [ sh:class capec:Technique ;
            sh:description "Specific techniques used by the adversary during this attack step." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path capec:techniques ] ;
    sh:targetClass capec:AttackStep .

capec:Category a sh:NodeShape ;
    rdfs:comment """A category in CAPEC is a collection of attack patterns based on some common
characteristic. More specifically, it is an aggregation of attack patterns based on
effect/intent (as opposed to actions or mechanisms, which would be a meta attack
pattern). An aggregation based on effect/intent is not an actionable attack and as
such is not a pattern of attack behavior. Rather, it is a grouping of patterns based
on some common criteria.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Unique integer identifier for the entry. Considered static for the lifetime of the entry. If an entry becomes deprecated, the identifier is not reused and a placeholder is left in the catalog." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:id ],
        [ sh:class capec:Reference ;
            sh:description "Links to external references for further reading and insight into this entry. Should be used when the entry is based on external sources or projects." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path capec:references ],
        [ sh:datatype xsd:string ;
            sh:description "A short summary limited to the key points that define this category." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path capec:summary ],
        [ sh:description "The development and usage status level for this entry. Please refer to the StatusEnum enumeration for a list of valid values and their meanings." ;
            sh:in ( "Deprecated" "Draft" "Incomplete" "Obsolete" "Stable" "Usable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path capec:status ],
        [ sh:datatype xsd:string ;
            sh:description "Descriptive title used to give the reader an idea of what the entry represents. All words in the name should be capitalized except for articles and prepositions unless they begin or end the name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:name ],
        [ sh:class capec:Note ;
            sh:description "Additional comments and notes about this entry that cannot be captured using the other available elements." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path capec:notes ],
        [ sh:class capec:Relationships ;
            sh:description "Relationships of this category with attack patterns, other categories, and views, including Member_Of and Has_Member relationships." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path capec:relationships ],
        [ sh:class capec:ContentHistory ;
            sh:description "Tracks the original author of this entry and any subsequent modifications to the content, providing a means of contacting authors and modifiers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path capec:content_history ],
        [ sh:class capec:TaxonomyMapping ;
            sh:description "Mappings from this entry to equivalent or related entries in taxonomies outside of CAPEC, such as ATT&CK, WASC, or OWASP Attacks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path capec:taxonomy_mappings ] ;
    sh:targetClass capec:Category .

capec:Consequence a sh:NodeShape ;
    rdfs:comment """An individual consequence associated with an attack pattern, specifying which
security properties are violated, the technical impact that arises if an adversary
succeeds, the likelihood of this specific consequence occurring, and any additional
commentary.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Internal CAPEC team identifier for consequences that repeat across many individual patterns. Used to keep repeated consequences synchronized. Format: CC-N (e.g., CC-1)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:consequence_id ],
        [ sh:description "Describes the negative technical impact(s) that arise if an adversary successfully achieves this consequence." ;
            sh:in ( "Modify Data" "Read Data" "Unreliable Execution" "Resource Consumption" "Execute Unauthorized Commands" "Gain Privileges" "Bypass Protection Mechanism" "Hide Activities" "Alter Execution Logic" "Other" ) ;
            sh:order 2 ;
            sh:path capec:impact ],
        [ sh:description "Identifies how likely this specific consequence is expected to be seen relative to the other consequences of the same attack pattern." ;
            sh:in ( "High" "Medium" "Low" "Unknown" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path capec:likelihood ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about this specific consequence." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path capec:note ],
        [ sh:description "Identifies the security property or properties that are violated when this consequence occurs. Multiple scopes may apply simultaneously." ;
            sh:in ( "Confidentiality" "Integrity" "Availability" "Access Control" "Accountability" "Authentication" "Authorization" "Non-Repudiation" "Other" ) ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path capec:scope ] ;
    sh:targetClass capec:Consequence .

capec:Contribution a sh:NodeShape ;
    rdfs:comment """A record of a contribution made to a CAPEC entry, identifying the contributor,
their organization, the date of contribution, the type of contribution (Content
or Feedback), and any related comments.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date on which this contribution was made." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path capec:contribution_date ],
        [ sh:description "Indicates whether the contribution was donated content or general feedback." ;
            sh:in ( "Content" "Feedback" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path capec:type ],
        [ sh:datatype xsd:string ;
            sh:description "Comments about the contribution and its significance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path capec:contribution_comment ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the person or team who made this contribution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:contribution_name ],
        [ sh:datatype xsd:string ;
            sh:description "The organization of the person who made this contribution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path capec:contribution_organization ] ;
    sh:targetClass capec:Contribution .

capec:ExternalReference a sh:NodeShape ;
    rdfs:comment """An external reference provides a pointer to where more information and deeper insight
can be obtained about an attack pattern, category, or view. Examples include research
papers and excerpts from publications. Not all elements need to be used since some are
designed for web references and others for book references.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The month of publication of the referenced material. Must follow the --MM format (xs:gMonth)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path capec:publication_month ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the magazine, journal, or other publication that contains the referenced material." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path capec:publication ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the publisher of the referenced material." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path capec:publisher ],
        [ sh:datatype xsd:date ;
            sh:description "The date when the URL was validated to be accessible and correct." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path capec:url_date ],
        [ sh:datatype xsd:string ;
            sh:description "The title of the referenced material." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path capec:title ],
        [ sh:datatype xsd:string ;
            sh:description "The author(s) of the referenced material." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:authors ],
        [ sh:datatype xsd:string ;
            sh:description "A globally unique identifier for this external reference (e.g., REF-1). Used by other entries to link to this reference using formats like [REF-1]." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:reference_id ],
        [ sh:datatype xsd:string ;
            sh:description "The edition of the material being referenced, in the event that multiple editions of the material exist." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path capec:edition ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A URL for the material being referenced, if one exists online." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path capec:url ],
        [ sh:datatype xsd:string ;
            sh:description "The day of publication of the referenced material. Must follow the ---DD format (xs:gDay)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path capec:publication_day ],
        [ sh:datatype xsd:string ;
            sh:description "The year of publication of the referenced material. Must follow the YYYY format (xs:gYear)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path capec:publication_year ] ;
    sh:targetClass capec:ExternalReference .

capec:HasMember a sh:NodeShape ;
    rdfs:comment """Represents a Has_Member relationship indicating that the parent category or view
contains the specified attack pattern or category as a member.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The CAPEC integer identifier of the attack pattern or category that is a member of this entry." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:capec_id ],
        [ sh:class capec:ExcludeRelated ;
            sh:description "CAPEC identifiers of ancestors for which this Has_Member relationship is not applicable (special cases only)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path capec:exclude_related ] ;
    sh:targetClass capec:HasMember .

capec:MemberOf a sh:NodeShape ;
    rdfs:comment """Represents a Member_Of relationship indicating that the parent category or view
is a member of the specified view or parent category.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The CAPEC integer identifier of the target view or category that this entry is a member of." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:capec_id ],
        [ sh:class capec:ExcludeRelated ;
            sh:description "CAPEC identifiers of ancestors for which this Member_Of relationship is not applicable (special cases only)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path capec:exclude_related ] ;
    sh:targetClass capec:MemberOf .

capec:Modification a sh:NodeShape ;
    rdfs:comment """A record of a modification made to a CAPEC entry, identifying the modifier,
their organization, the date of modification, the importance of the change,
and any related comments. Modifications that change the meaning of the entry
should be marked as Critical importance.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The organization of the person who made this modification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:modification_organization ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which this modification was made." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path capec:modification_date ],
        [ sh:datatype xsd:string ;
            sh:description "Comments describing the nature and reason for this modification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path capec:modification_comment ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the person or team who made this modification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:modification_name ],
        [ sh:description "The importance level of this modification. Modifications that change the meaning of the entry or how it might be interpreted should be marked Critical." ;
            sh:in ( "Normal" "Critical" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path capec:modification_importance ] ;
    sh:targetClass capec:Modification .

capec:PreviousEntryName a sh:NodeShape ;
    rdfs:comment """A previous name that was used for a CAPEC entry before a substantive name change.
Should align with a corresponding Modification element that records the change.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The previous name that was used for this entry." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:name ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which this name change was made." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:entry_date ] ;
    sh:targetClass capec:PreviousEntryName .

capec:RelatedAttackPattern a sh:NodeShape ;
    rdfs:comment """A reference to another attack pattern that provides insight to similar items at
higher or lower levels of abstraction, or items that are part of a chaining or
peer relationship. Special cases may require Exclude_Related elements to capture
ancestor IDs for which this relationship is not applicable.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class capec:ExcludeRelated ;
            sh:description "One or more CAPEC identifiers of ancestors for which this relationship is not applicable (special cases only)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path capec:exclude_related ],
        [ sh:description "The nature of the relationship (ChildOf, ParentOf, CanFollow, CanPrecede, CanAlsoBe, or PeerOf)." ;
            sh:in ( "ChildOf" "ParentOf" "CanFollow" "CanPrecede" "CanAlsoBe" "PeerOf" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path capec:nature ],
        [ sh:datatype xsd:integer ;
            sh:description "The unique CAPEC integer identifier of the related attack pattern." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:capec_id ] ;
    sh:targetClass capec:RelatedAttackPattern .

capec:Skill a sh:NodeShape ;
    rdfs:comment "A description of the level of skills or specific knowledge needed by an adversary to execute this type of attack. Each skill entry captures both the skill level and a textual description of the knowledge required." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The skill or knowledge level required (High, Medium, Low, or Unknown)." ;
            sh:in ( "High" "Medium" "Low" "Unknown" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path capec:level ],
        [ sh:datatype xsd:string ;
            sh:description "Textual description of the specific skills or knowledge the adversary must possess to execute this attack at the given skill level." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:description ] ;
    sh:targetClass capec:Skill .

capec:Stakeholder a sh:NodeShape ;
    rdfs:comment """A target stakeholder or group for whom a CAPEC view is relevant. Specifies
the type of stakeholder and describes which properties of the view they may
find useful.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The type of stakeholder or group that might be interested in the view." ;
            sh:in ( "Academic Researchers" "Applied Researchers" "Assessment Customers" "Assessment Vendors" "CAPEC Team" "Educators" "Information Providers" "Software Customers" "Software Designers" "Software Developers" "Software Vendors" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path capec:type ],
        [ sh:datatype xsd:string ;
            sh:description "A description of what properties of the view this particular stakeholder might find useful and how it applies to their work." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:description ] ;
    sh:targetClass capec:Stakeholder .

capec:Submission a sh:NodeShape ;
    rdfs:comment """Information about the original submission of a CAPEC entry, identifying the
submitter, their organization, the date of submission, and any related comments.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the person or team who originally submitted this entry." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:submission_name ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which this entry was originally submitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path capec:submission_date ],
        [ sh:datatype xsd:string ;
            sh:description "Any comments related to the original submission of this entry." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path capec:submission_comment ],
        [ sh:datatype xsd:string ;
            sh:description "The organization of the person who originally submitted this entry." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:submission_organization ] ;
    sh:targetClass capec:Submission .

capec:Technique a sh:NodeShape ;
    rdfs:comment "A specific technique used by an adversary during an attack step. Extends the structured text description with an optional reference to a related CAPEC entry." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Description of the specific technique, potentially containing XHTML markup." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:description ],
        [ sh:datatype xsd:string ;
            sh:description "Optional reference to a related CAPEC entry ID relevant to this technique." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:capec_id ] ;
    sh:targetClass capec:Technique .

capec:View a sh:NodeShape ;
    rdfs:comment """A view in CAPEC represents a perspective with which one might look at the collection
of attack patterns defined within CAPEC. There are three different types of views as
defined by the Type attribute: graphs, explicit slices, and implicit slices.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class capec:ContentHistory ;
            sh:description "Tracks the original author of this entry and any subsequent modifications to the content, providing a means of contacting authors and modifiers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path capec:content_history ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the perspective from which this view has been constructed and what purpose it serves for its intended audience." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path capec:objective ],
        [ sh:class capec:Relationships ;
            sh:description "The members of this view, defined via Member_Of and Has_Member relationships (applicable to graph and explicit slice view types)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path capec:members ],
        [ sh:class capec:Stakeholder ;
            sh:description "Reference to the target stakeholders or groups for whom this view is most relevant, along with descriptions of what properties they may find useful." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path capec:audience ],
        [ sh:datatype xsd:integer ;
            sh:description "Unique integer identifier for the entry. Considered static for the lifetime of the entry. If an entry becomes deprecated, the identifier is not reused and a placeholder is left in the catalog." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:id ],
        [ sh:class capec:Note ;
            sh:description "Additional comments and notes about this entry that cannot be captured using the other available elements." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path capec:notes ],
        [ sh:datatype xsd:string ;
            sh:description "An XSL query used to identify which attack patterns are members of this view. Only applicable to implicit slice view types." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path capec:filter ],
        [ sh:description "The development and usage status level for this entry. Please refer to the StatusEnum enumeration for a list of valid values and their meanings." ;
            sh:in ( "Deprecated" "Draft" "Incomplete" "Obsolete" "Stable" "Usable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path capec:status ],
        [ sh:datatype xsd:string ;
            sh:description "Descriptive title used to give the reader an idea of what the entry represents. All words in the name should be capitalized except for articles and prepositions unless they begin or end the name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:name ],
        [ sh:class capec:Reference ;
            sh:description "Links to external references for further reading and insight into this entry. Should be used when the entry is based on external sources or projects." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path capec:references ],
        [ sh:description "Describes how this view is constructed. Please refer to ViewTypeEnum for a list of valid values and their meanings." ;
            sh:in ( "Implicit" "Explicit" "Graph" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path capec:type ] ;
    sh:targetClass capec:View .

capec:Relationships a sh:NodeShape ;
    rdfs:comment """A container for relationships associated with a category or view, showing
Member_Of relationships with views or categories and Has_Member relationships
with attack patterns or categories.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class capec:MemberOf ;
            sh:description "Member_Of relationships showing that this category or view is a member of a given view or parent category, identified by CAPEC_ID." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path capec:member_of ],
        [ sh:class capec:HasMember ;
            sh:description "Has_Member relationships showing that this category or view contains a given attack pattern or category as a member, identified by CAPEC_ID." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path capec:has_member ] ;
    sh:targetClass capec:Relationships .

capec:TaxonomyMapping a sh:NodeShape ;
    rdfs:comment """A mapping from a CAPEC entry (AttackPattern or Category) to an equivalent or related
entry in a different security taxonomy. Identifies the external taxonomy, the ID and
name of the external entry, and how closely the CAPEC entry aligns with it.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the entry in the external taxonomy that this CAPEC entry is being mapped to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path capec:entry_name ],
        [ sh:description "Identifies the external taxonomy to which this mapping is being made." ;
            sh:in ( "ATTACK" "WASC" "OWASP Attacks" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path capec:taxonomy_name ],
        [ sh:datatype xsd:string ;
            sh:description "The identifier of the entry in the external taxonomy that this CAPEC entry is being mapped to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:entry_id ],
        [ sh:description "Identifies how closely the CAPEC entry aligns with the external taxonomy entry (Exact, CAPEC More Abstract, CAPEC More Specific, Imprecise, or Perspective)." ;
            sh:in ( "Exact" "CAPEC More Abstract" "CAPEC More Specific" "Imprecise" "Perspective" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path capec:mapping_fit ] ;
    sh:targetClass capec:TaxonomyMapping .

capec:ContentHistory a sh:NodeShape ;
    rdfs:comment """Tracks the original author of a CAPEC entry and any subsequent modifications
to the content. Provides a means of contacting authors and modifiers for
clarifying ambiguities, merging overlapping contributions, etc.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class capec:PreviousEntryName ;
            sh:description "Previous names that were used for this entry. Should be recorded whenever a substantive name change occurs, aligned with a corresponding Modification." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path capec:previous_entry_names ],
        [ sh:class capec:Submission ;
            sh:description "Identifies the original submitter, their organization, the submission date, and any comments related to the initial entry submission." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path capec:submission ],
        [ sh:class capec:Contribution ;
            sh:description "Records of contributions made to the entry, identifying contributors and whether their input was donated content or general feedback." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path capec:contributions ],
        [ sh:class capec:Modification ;
            sh:description "Records of modifications made to the entry content. A new Modification entry should exist for each change made." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path capec:modifications ] ;
    sh:targetClass capec:ContentHistory .

capec:ExcludeRelated a sh:NodeShape ;
    rdfs:comment """Captures the CAPEC identifier of an ancestor for which a given relationship is
not applicable. Used in special cases within RelatedAttackPattern and relationship
entries.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The CAPEC integer identifier of the ancestor entry for which the relationship is not applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:exclude_id ] ;
    sh:targetClass capec:ExcludeRelated .

capec:Note a sh:NodeShape ;
    rdfs:comment "An additional comment about a CAPEC entry that cannot be captured using the other available elements. Each note has a type indicating its purpose and contains content describing the note." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The type of note, indicating its purpose (Maintenance, Relationship, Research Gap, Terminology, or Other)." ;
            sh:in ( "Maintenance" "Relationship" "Research Gap" "Terminology" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path capec:type ],
        [ sh:datatype xsd:string ;
            sh:description "The content of the note, potentially containing XHTML markup." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:content ] ;
    sh:targetClass capec:Note .

capec:Reference a sh:NodeShape ;
    rdfs:comment """A link from a CAPEC entry to an external reference defined within the catalog.
The External_Reference_ID identifies which external reference is being cited.
An optional Section captures a specific section title or page number relevant
to this use of the reference.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The identifier of the external reference entry being linked to (e.g., REF-1). Must match a Reference_ID in the catalog's External_References." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path capec:external_reference_id ],
        [ sh:datatype xsd:string ;
            sh:description "A specific section title or page number within the referenced material that is particularly relevant to this use of the reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path capec:section ] ;
    sh:targetClass capec:Reference .

