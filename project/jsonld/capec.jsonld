          "value": "ContentHistoryType",
          "@type": "Annotation"
        }
      ],
      "description": "Tracks the original author of a CAPEC entry and any subsequent modifications\nto the content. Provides a means of contacting authors and modifiers for\nclarifying ambiguities, merging overlapping contributions, etc.",
      "in_subset": [
        "content_history_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
