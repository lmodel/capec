      "annotations": [
        {
          "tag": "xsd_type",
          "value": "AudienceType/Stakeholder (inline)",
          "@type": "Annotation"
        }
      ],
      "description": "A target stakeholder or group for whom a CAPEC view is relevant. Specifies\nthe type of stakeholder and describes which properties of the view they may\nfind useful.",
