      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/MemberOf",
      "@type": "ClassDefinition"
    },
    {
      "name": "HasMember",
      "definition_uri": "https://w3id.org/lmodel/capec/HasMember",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "RelationshipsType/Has_Member (inline)",
          "@type": "Annotation"
        }
      ],
      "description": "Represents a Has_Member relationship indicating that the parent category or view\ncontains the specified attack pattern or category as a member.",
      "in_subset": [
        "relationship_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "HasMember_capec_id",
