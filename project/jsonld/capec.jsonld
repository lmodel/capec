      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/Relationships",
      "@type": "ClassDefinition"
    },
    {
      "name": "MemberOf",
      "definition_uri": "https://w3id.org/lmodel/capec/MemberOf",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "RelationshipsType/Member_Of (inline)",
          "@type": "Annotation"
        }
      ],
      "description": "Represents a Member_Of relationship indicating that the parent category or view\nis a member of the specified view or parent category.",
      "in_subset": [
        "relationship_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
