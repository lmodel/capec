  "classes": [
    {
      "name": "AttackPatternCatalog",
      "definition_uri": "https://w3id.org/lmodel/capec/AttackPatternCatalog",
      "annotations": [
        {
          "tag": "xsd_element",
          "value": "Attack_Pattern_Catalog",
          "@type": "Annotation"
        },
        {
          "tag": "xsd_constraint",
          "value": "uniqueAttackPatternID on Attack_Patterns/Attack_Pattern/@ID; uniqueCategoryID on Categories/Category/@ID; uniqueViewID on Views/View/@ID; uniqueReferenceID on External_References/External_Reference/@Reference_ID",
          "@type": "Annotation"
        },
        {
          "tag": "view_export_note",
          "value": "View-filtered catalog exports follow the naming convention \"VIEW LIST: CAPEC-{ID}: {Name}\" in the Name attribute. These exports are self-contained: they include the relevant Attack_Patterns, exactly one View entry (the view being exported), the External_References cited by those patterns, and \u2014 when applicable \u2014 the Categories that are part of the view. Source files for navigation hierarchies, abstraction/status slices, thematic views, and vendor taxonomy mappings reside in tests/data/capec/navigation/, tests/data/capec/views/, and src/capec/mappings/ respectively.",
          "@type": "Annotation"
        }
      ],
      "description": "The root element used to hold an enumerated catalog of common attack patterns.\nEach catalog can be organized by optional Views and Categories. The catalog also\ncontains a list of all External_References that may be shared throughout the\nindividual attack patterns. The required Name and Version attributes are used to\nuniquely identify the catalog. The required Date attribute identifies the date when\nthis catalog was created or last updated.",
      "in_subset": [
        "catalog_entries"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "AttackPatternCatalog_name",
        "AttackPatternCatalog_version",
        "AttackPatternCatalog_entry_date",
        "AttackPatternCatalog_attack_patterns",
        "AttackPatternCatalog_categories",
        "AttackPatternCatalog_views",
        "AttackPatternCatalog_external_references"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/AttackPatternCatalog",
      "tree_root": true,
      "@type": "ClassDefinition"
    },
    {
      "name": "AttackPattern",
      "definition_uri": "https://w3id.org/lmodel/capec/AttackPattern",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "AttackPatternType",
          "@type": "Annotation"
        },
        {
          "tag": "description_note",
          "value": "The required Description element represents a high level description of the attack pattern (no longer than a few sentences). The optional Extended_Description element provides additional details. Typical_Severity and Likelihood_Of_Attack capture average values with the understanding they will not be accurate for all attacks.",
          "@type": "Annotation"
        }
      ],
      "description": "An attack pattern is an abstraction mechanism for helping describe how an attack is\nexecuted. Each pattern defines a challenge that an attacker may face, provides a\ndescription of the common technique(s) used to meet the challenge, and presents\nrecommended methods for mitigating an actual attack. Attack patterns help categorize\nattacks in a meaningful way in an effort to provide a coherent way of teaching\ndesigners and developers how their systems may be attacked and how they can effectively\ndefend them.",
      "in_subset": [
        "catalog_entries"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "close_mappings": [
        "stix:attack-pattern"
      ],
      "related_mappings": [
        "attack:Technique",
        "wasc:Threat",
        "owasp:Attack"
      ],
      "slots": [
        "id",
        "name",
        "status",
        "AttackPattern_description",
        "notes",
        "content_history",
        "references",
        "taxonomy_mappings",
        "AttackPattern_abstraction",
        "AttackPattern_extended_description",
        "AttackPattern_alternate_terms",
        "AttackPattern_likelihood_of_attack",
        "AttackPattern_typical_severity",
        "AttackPattern_related_attack_patterns",
        "AttackPattern_execution_flow",
        "AttackPattern_prerequisites",
        "AttackPattern_skills_required",
        "AttackPattern_resources_required",
        "AttackPattern_indicators",
        "AttackPattern_consequences",
        "AttackPattern_mitigations",
        "AttackPattern_example_instances",
        "AttackPattern_related_weaknesses"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/AttackPattern",
      "@type": "ClassDefinition"
    },
    {
      "name": "Category",
      "definition_uri": "https://w3id.org/lmodel/capec/Category",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "CategoryType",
          "@type": "Annotation"
        }
      ],
      "description": "A category in CAPEC is a collection of attack patterns based on some common\ncharacteristic. More specifically, it is an aggregation of attack patterns based on\neffect/intent (as opposed to actions or mechanisms, which would be a meta attack\npattern). An aggregation based on effect/intent is not an actionable attack and as\nsuch is not a pattern of attack behavior. Rather, it is a grouping of patterns based\non some common criteria.",
      "in_subset": [
        "catalog_entries"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "id",
        "name",
        "status",
        "notes",
        "content_history",
        "references",
        "taxonomy_mappings",
        "Category_summary",
        "Category_relationships"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/Category",
      "@type": "ClassDefinition"
    },
    {
      "name": "View",
      "definition_uri": "https://w3id.org/lmodel/capec/View",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "ViewType",
          "@type": "Annotation"
        },
        {
          "tag": "notes",
          "value": "Members of a view are either defined externally through Member_Of relationships (for graphs and explicit slices) or by the optional Filter element as an XSL query (for implicit slices).",
          "@type": "Annotation"
        }
      ],
      "description": "A view in CAPEC represents a perspective with which one might look at the collection\nof attack patterns defined within CAPEC. There are three different types of views as\ndefined by the Type attribute: graphs, explicit slices, and implicit slices.",
      "in_subset": [
        "catalog_entries"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "id",
        "name",
        "status",
        "View_type",
        "notes",
        "content_history",
        "references",
        "View_objective",
        "View_audience",
        "View_members",
        "View_filter"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/View",
      "@type": "ClassDefinition"
    },
    {
      "name": "ExternalReference",
      "definition_uri": "https://w3id.org/lmodel/capec/ExternalReference",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "ExternalReferenceType",
          "@type": "Annotation"
        },
        {
          "tag": "notes",
          "value": "The Author and Title elements should be filled in for all references if possible. URL and URL_Date are used for web references. Publication_Year must follow YYYY format; Publication_Month must follow --MM format; Publication_Day must follow ---DD format.",
          "@type": "Annotation"
        }
      ],
      "description": "An external reference provides a pointer to where more information and deeper insight\ncan be obtained about an attack pattern, category, or view. Examples include research\npapers and excerpts from publications. Not all elements need to be used since some are\ndesigned for web references and others for book references.",
      "in_subset": [
        "catalog_entries"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "ExternalReference_reference_id",
        "ExternalReference_authors",
        "ExternalReference_title",
        "ExternalReference_edition",
        "ExternalReference_publication",
        "ExternalReference_publication_year",
        "ExternalReference_publication_month",
        "ExternalReference_publication_day",
        "ExternalReference_publisher",
        "ExternalReference_url",
        "ExternalReference_url_date"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/ExternalReference",
      "@type": "ClassDefinition"
    },
    {
      "name": "AlternateTerm",
      "definition_uri": "https://w3id.org/lmodel/capec/AlternateTerm",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "AlternateTermsType/Alternate_Term (inline)",
          "@type": "Annotation"
        }
      ],
      "description": "Another name or term used to describe an attack pattern. Provides context for the alternate term by which the attack pattern may be known.",
      "in_subset": [
        "attack_pattern_content"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "AlternateTerm_description",
        "AlternateTerm_term"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/AlternateTerm",
      "@type": "ClassDefinition"
    },
    {
      "name": "Consequence",
      "definition_uri": "https://w3id.org/lmodel/capec/Consequence",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "ConsequencesType/Consequence (inline)",
          "@type": "Annotation"
        },
        {
          "tag": "notes",
          "value": "The optional Consequence_ID attribute is used internally by the CAPEC team to uniquely identify consequences repeated across patterns. The identifier format is CC-N (e.g., CC-1).",
          "@type": "Annotation"
        }
      ],
      "description": "An individual consequence associated with an attack pattern, specifying which\nsecurity properties are violated, the technical impact that arises if an adversary\nsucceeds, the likelihood of this specific consequence occurring, and any additional\ncommentary.",
      "in_subset": [
        "attack_pattern_content"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "Consequence_consequence_id",
        "Consequence_scope",
        "Consequence_impact",
        "Consequence_likelihood",
        "Consequence_note"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/Consequence",
      "@type": "ClassDefinition"
    },
    {
      "name": "Skill",
      "definition_uri": "https://w3id.org/lmodel/capec/Skill",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "SkillsType/Skill (inline simpleContent extension)",
          "@type": "Annotation"
        }
      ],
      "description": "A description of the level of skills or specific knowledge needed by an adversary to execute this type of attack. Each skill entry captures both the skill level and a textual description of the knowledge required.",
      "in_subset": [
        "attack_pattern_content"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "Skill_description",
        "Skill_level"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/Skill",
      "@type": "ClassDefinition"
    },
    {
      "name": "Note",
      "definition_uri": "https://w3id.org/lmodel/capec/Note",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "NotesType/Note (inline complexContent extension of StructuredTextType)",
          "@type": "Annotation"
        }
      ],
      "description": "An additional comment about a CAPEC entry that cannot be captured using the other available elements. Each note has a type indicating its purpose and contains content describing the note.",
      "in_subset": [
        "attack_pattern_content"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "Note_type",
        "Note_content"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/Note",
      "@type": "ClassDefinition"
    },
    {
      "name": "AttackStep",
      "definition_uri": "https://w3id.org/lmodel/capec/AttackStep",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "ExecutionFlowType/Attack_Step (inline)",
          "@type": "Annotation"
        }
      ],
      "description": "An individual step in the execution flow of an attack pattern. Provides a detailed\ndescription of a specific action typically performed by an adversary during the\nattack, along with the phase of the attack it belongs to and any specific techniques\nused.",
      "in_subset": [
        "execution_flow_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "AttackStep_description",
        "AttackStep_step",
        "AttackStep_phase",
        "AttackStep_techniques"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/AttackStep",
      "@type": "ClassDefinition"
    },
    {
      "name": "Technique",
      "definition_uri": "https://w3id.org/lmodel/capec/Technique",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "ExecutionFlowType/Attack_Step/Technique (inline complexContent extension of StructuredTextType)",
          "@type": "Annotation"
        }
      ],
      "description": "A specific technique used by an adversary during an attack step. Extends the structured text description with an optional reference to a related CAPEC entry.",
      "in_subset": [
        "execution_flow_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "Technique_capec_id",
        "Technique_description"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/Technique",
      "@type": "ClassDefinition"
    },
    {
      "name": "RelatedAttackPattern",
      "definition_uri": "https://w3id.org/lmodel/capec/RelatedAttackPattern",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "RelatedAttackPatternType/Related_Attack_Pattern (inline)",
          "@type": "Annotation"
        }
      ],
      "description": "A reference to another attack pattern that provides insight to similar items at\nhigher or lower levels of abstraction, or items that are part of a chaining or\npeer relationship. Special cases may require Exclude_Related elements to capture\nancestor IDs for which this relationship is not applicable.",
      "in_subset": [
        "relationship_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "RelatedAttackPattern_capec_id",
        "RelatedAttackPattern_exclude_related",
        "RelatedAttackPattern_nature"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/RelatedAttackPattern",
      "@type": "ClassDefinition"
    },
    {
      "name": "ExcludeRelated",
      "definition_uri": "https://w3id.org/lmodel/capec/ExcludeRelated",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "ExcludeRelatedType",
          "@type": "Annotation"
        }
      ],
      "description": "Captures the CAPEC identifier of an ancestor for which a given relationship is\nnot applicable. Used in special cases within RelatedAttackPattern and relationship\nentries.",
      "in_subset": [
        "relationship_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "ExcludeRelated_exclude_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/ExcludeRelated",
      "@type": "ClassDefinition"
    },
    {
      "name": "RelatedWeakness",
      "definition_uri": "https://w3id.org/lmodel/capec/RelatedWeakness",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "RelatedWeaknessesType/Related_Weakness (inline)",
          "@type": "Annotation"
        }
      ],
      "description": "A reference to a CWE (Common Weakness Enumeration) weakness associated with an\nattack pattern. The association implies a weakness that must exist for a given\nattack to be successful. If multiple weaknesses are listed, any of them (but not\nnecessarily all) may be present for the attack to succeed.",
      "in_subset": [
        "relationship_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "RelatedWeakness_cwe_id"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/RelatedWeakness",
      "@type": "ClassDefinition"
    },
    {
      "name": "Relationships",
      "definition_uri": "https://w3id.org/lmodel/capec/Relationships",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "RelationshipsType",
          "@type": "Annotation"
        }
      ],
      "description": "A container for relationships associated with a category or view, showing\nMember_Of relationships with views or categories and Has_Member relationships\nwith attack patterns or categories.",
      "in_subset": [
        "relationship_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "Relationships_member_of",
