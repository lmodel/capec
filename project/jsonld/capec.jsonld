      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/HasMember",
      "@type": "ClassDefinition"
    },
    {
      "name": "Reference",
      "definition_uri": "https://w3id.org/lmodel/capec/Reference",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "ReferencesType/Reference (inline)",
          "@type": "Annotation"
        },
        {
          "tag": "notes",
          "value": "Text or quotes within an entry can cite the External_Reference_ID using the format [REF-N] as a footnote-style citation.",
          "@type": "Annotation"
        }
      ],
      "description": "A link from a CAPEC entry to an external reference defined within the catalog.\nThe External_Reference_ID identifies which external reference is being cited.\nAn optional Section captures a specific section title or page number relevant\nto this use of the reference.",
      "in_subset": [
        "relationship_types"
      ],
      "from_schema": "https://w3id.org/lmodel/capec",
      "slots": [
        "Reference_external_reference_id",
        "Reference_section"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/lmodel/capec/Reference",
      "@type": "ClassDefinition"
    },
    {
      "name": "TaxonomyMapping",
      "definition_uri": "https://w3id.org/lmodel/capec/TaxonomyMapping",
      "annotations": [
        {
          "tag": "xsd_type",
          "value": "TaxonomyMappingsType/Taxonomy_Mapping (inline)",
          "@type": "Annotation"
        }
      ],
      "description": "A mapping from a CAPEC entry (AttackPattern or Category) to an equivalent or related\nentry in a different security taxonomy. Identifies the external taxonomy, the ID and\nname of the external entry, and how closely the CAPEC entry aligns with it.",
